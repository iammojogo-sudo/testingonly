    {
      "id": "paint-texture",
      "name": "Apply Texture (Paint)",
      "input": "image",
      "inputs": [
        { "id": "front_image", "type": "image", "label": "Front" },
        { "id": "left_image",  "type": "image", "label": "Left (optional)"  },
        { "id": "back_image",  "type": "image", "label": "Back (optional)"  },
        { "id": "right_image", "type": "image", "label": "Right (optional)" }
      ],
      "output": "mesh",
      "hf_repo": "tencent/Hunyuan3D-2",
      "download_check": "hunyuan3d-paint-v2-0/model_index.json",
      "params_schema": [
        {
          "id": "mesh_path",
          "label": "Mesh Path",
          "type": "string",
          "default": "",
          "tooltip": "Full path to your untextured .glb file. Example: C:\\Users\\You\\mesh.glb"
        },
        {
          "id": "max_num_view",
          "label": "Paint Views",
          "type": "select",
          "default": 6,
          "options": [
            { "value": 6, "label": "6 — faster, less VRAM" },
            { "value": 7, "label": "7"                     },
            { "value": 8, "label": "8"                     },
            { "value": 9, "label": "9 — best coverage"     }
          ],
          "tooltip": "How many angles the model paints from. More views = better coverage but more VRAM and time."
        },
        {
          "id": "resolution",
          "label": "Texture Resolution",
          "type": "select",
          "default": 512,
          "options": [
            { "value": 512,  "label": "512 — faster (~16 GB VRAM)"   },
            { "value": 1024, "label": "1024 — sharper (~21 GB VRAM)" }
          ],
          "tooltip": "Output texture map resolution. 512 is recommended unless you have 21+ GB VRAM."
        },
        {
          "id": "remove_bg",
          "label": "Remove Background",
          "type": "select",
          "default": "true",
          "options": [
            { "value": "true",  "label": "Yes — auto remove background" },
            { "value": "false", "label": "No — images already masked"   }
          ],
          "tooltip": "Strip background from all reference images before texturing."
        }
      ],
